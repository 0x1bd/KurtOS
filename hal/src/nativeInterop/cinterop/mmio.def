headers =
compilerOpts = -ffreestanding
---
#include <stdint.h>

static inline uint8_t port_in8(uint16_t port) {
    uint8_t value;
    __asm__ volatile("inb %1, %0" : "=a"(value) : "Nd"(port));
    return value;
}

static inline void port_out8(uint16_t port, uint8_t value) {
    __asm__ volatile("outb %0, %1" : : "a"(value), "Nd"(port));
}

static inline uint16_t port_in16(uint16_t port) {
    uint16_t value;
    __asm__ volatile("inw %1, %0" : "=a"(value) : "Nd"(port));
    return value;
}

static inline void port_out16(uint16_t port, uint16_t value) {
    __asm__ volatile("outw %0, %1" : : "a"(value), "Nd"(port));
}

static inline uint32_t port_in32(uint16_t port) {
    uint32_t value;
    __asm__ volatile("inl %1, %0" : "=a"(value) : "Nd"(port));
    return value;
}

static inline void port_out32(uint16_t port, uint32_t value) {
    __asm__ volatile("outl %0, %1" : : "a"(value), "Nd"(port));
}

static inline void io_wait(void) {
    port_out8(0x80, 0);
}

static inline uint64_t msr_read(uint32_t msr) {
    uint32_t lo, hi;
    __asm__ volatile("rdmsr" : "=a"(lo), "=d"(hi) : "c"(msr));
    return ((uint64_t)hi << 32) | lo;
}

static inline void msr_write(uint32_t msr, uint64_t value) {
    __asm__ volatile("wrmsr" : : "c"(msr), "a"((uint32_t)value), "d"((uint32_t)(value >> 32)));
}

static inline uint64_t cpu_read_cr2(void) {
    uint64_t value;
    __asm__ volatile("mov %%cr2, %0" : "=r"(value));
    return value;
}

static inline uint64_t cpu_rdtsc(void) {
    uint32_t lo, hi;
    __asm__ volatile("rdtsc" : "=a"(lo), "=d"(hi));
    return ((uint64_t)hi << 32) | lo;
}

static inline void cpu_cpuid(uint32_t leaf, uint32_t *a, uint32_t *b, uint32_t *c, uint32_t *d) {
    __asm__ volatile("cpuid" : "=a"(*a), "=b"(*b), "=c"(*c), "=d"(*d) : "a"(leaf), "c"(0));
}

static inline void cpu_enable_interrupts(void) {
    __asm__ volatile("sti");
}

static inline void cpu_disable_interrupts(void) {
    __asm__ volatile("cli");
}

static inline void cpu_halt(void) {
    __asm__ volatile("sti; hlt");
}

static inline void cpu_hang(void) {
    for (;;) __asm__ volatile("cli; hlt");
}

static inline uint8_t raw_read8(uint64_t addr) {
    return *((volatile uint8_t*)addr);
}

static inline uint16_t raw_read16(uint64_t addr) {
    return *((volatile uint16_t*)addr);
}

static inline uint32_t raw_read32(uint64_t addr) {
    return *((volatile uint32_t*)addr);
}

static inline uint64_t raw_read64(uint64_t addr) {
    return *((volatile uint64_t*)addr);
}

static inline void raw_write8(uint64_t addr, uint8_t value) {
    *((volatile uint8_t*)addr) = value;
}

static inline void raw_write16(uint64_t addr, uint16_t value) {
    *((volatile uint16_t*)addr) = value;
}

static inline void raw_write32(uint64_t addr, uint32_t value) {
    *((volatile uint32_t*)addr) = value;
}

static inline void raw_write64(uint64_t addr, uint64_t value) {
    *((volatile uint64_t*)addr) = value;
}

static inline void raw_fill32(uint64_t addr, uint32_t value, uint64_t count) {
    uint32_t *p = (uint32_t*)addr;
    for (uint64_t i = 0; i < count; i++) p[i] = value;
}

static inline void raw_copy(uint64_t dst, uint64_t src, uint64_t bytes) {
    __builtin_memcpy((void*)dst, (const void*)src, bytes);
}

static inline void raw_blit_indexed(uint64_t dst, uint64_t dst_stride, uint64_t src,
                                    uint32_t src_w, uint32_t src_h,
                                    uint64_t palette, uint32_t scale) {
    const uint8_t *pixels = (const uint8_t*)src;
    const uint32_t *colors = (const uint32_t*)palette;

    for (uint32_t y = 0; y < src_h; y++) {
        const uint8_t *row = pixels + (uint64_t)y * src_w;
        for (uint32_t sy = 0; sy < scale; sy++) {
            uint32_t *out = (uint32_t*)(dst + ((uint64_t)y * scale + sy) * dst_stride);
            for (uint32_t x = 0; x < src_w; x++) {
                uint32_t color = colors[row[x]];
                for (uint32_t sx = 0; sx < scale; sx++) *out++ = color;
            }
        }
    }
}

static inline void raw_zero(uint64_t addr, uint64_t bytes) {
    __builtin_memset((void*)addr, 0, bytes);
}

typedef struct {
    uint64_t base;
    uint64_t length;
    uint64_t type;
} kurtos_memmap_entry_t;

typedef struct {
    uint64_t hhdm_offset;
    uint64_t fb_address;
    uint64_t fb_width;
    uint64_t fb_height;
    uint64_t fb_pitch;
    uint32_t fb_bpp;
    uint32_t fb_present;
    uint32_t fb_red_shift;
    uint32_t fb_green_shift;
    uint32_t fb_blue_shift;
    uint64_t module_address;
    uint64_t module_size;
    uint64_t rsdp_address;
    uint64_t heap_start;
    uint64_t heap_end;
    uint64_t pages_start;
    uint64_t pages_end;
    uint64_t memmap_count;
    kurtos_memmap_entry_t memmap[64];
} kurtos_boot_info_t;

extern kurtos_boot_info_t kurtos_boot_info;
extern uint64_t kurtos_lapic_base;
extern uint64_t kurtos_ticks;

extern int kbd_ring_pop(void);
extern uint64_t kbd_ring_overflows(void);
extern void lgdt_load(void *ptr, uint16_t code_sel, uint16_t data_sel);
extern void ltr_load(uint16_t sel);
extern void lidt_load(void *ptr);
extern void *isr_stub_table[];
extern uint64_t heap_used(void);
extern uint64_t heap_total(void);

static inline uint64_t boot_hhdm(void) { return kurtos_boot_info.hhdm_offset; }
static inline uint64_t boot_fb_address(void) { return kurtos_boot_info.fb_address; }
static inline uint64_t boot_fb_width(void) { return kurtos_boot_info.fb_width; }
static inline uint64_t boot_fb_height(void) { return kurtos_boot_info.fb_height; }
static inline uint64_t boot_fb_pitch(void) { return kurtos_boot_info.fb_pitch; }
static inline uint32_t boot_fb_present(void) { return kurtos_boot_info.fb_present; }
static inline uint32_t boot_fb_red_shift(void) { return kurtos_boot_info.fb_red_shift; }
static inline uint32_t boot_fb_green_shift(void) { return kurtos_boot_info.fb_green_shift; }
static inline uint32_t boot_fb_blue_shift(void) { return kurtos_boot_info.fb_blue_shift; }
static inline uint64_t boot_module_address(void) { return kurtos_boot_info.module_address; }
static inline uint64_t boot_module_size(void) { return kurtos_boot_info.module_size; }
static inline uint64_t boot_rsdp(void) { return kurtos_boot_info.rsdp_address; }
static inline uint64_t boot_heap_start(void) { return kurtos_boot_info.heap_start; }
static inline uint64_t boot_heap_end(void) { return kurtos_boot_info.heap_end; }
static inline uint64_t boot_pages_start(void) { return kurtos_boot_info.pages_start; }
static inline uint64_t boot_pages_end(void) { return kurtos_boot_info.pages_end; }
static inline uint64_t boot_memmap_count(void) { return kurtos_boot_info.memmap_count; }
static inline uint64_t boot_memmap_base(uint64_t i) { return kurtos_boot_info.memmap[i].base; }
static inline uint64_t boot_memmap_length(uint64_t i) { return kurtos_boot_info.memmap[i].length; }
static inline uint64_t boot_memmap_type(uint64_t i) { return kurtos_boot_info.memmap[i].type; }

static inline uint64_t timer_ticks(void) { return kurtos_ticks; }
static inline void lapic_base_set(uint64_t base) { kurtos_lapic_base = base; }

static inline uint64_t isr_stub(uint64_t vector) { return (uint64_t)isr_stub_table[vector]; }
